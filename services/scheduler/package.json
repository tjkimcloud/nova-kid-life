{
  "name": "@novakidlife/scheduler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "pytest tests/ -v",
    "test:watch": "pytest tests/ -v --watch",
    "lint": "ruff check . && ruff format --check .",
    "format": "ruff format .",
    "typecheck": "mypy handler.py",
    "package": "bash scripts/package.sh",
    "invoke": "aws lambda invoke --function-name novakidlife-scheduler --payload '{\"source\":\"aws.events\"}' /tmp/response.json && cat /tmp/response.json",
    "logs": "aws logs tail /aws/lambda/novakidlife-scheduler --follow",
    "rules": "aws events list-rules --name-prefix novakidlife"
  }
}
